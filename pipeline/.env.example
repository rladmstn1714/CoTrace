# Copy this file to .env and fill in the keys you need.
# Do not commit .env.

# Default provider and OpenAI embeddings
OPENAI_API_KEY=

# Optional: choose defaults without CLI flags
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5.2

# Optional: Google Gemini provider
# GEMINI_API_KEY=

# Optional: OpenRouter provider
# OPENROUTER_API_KEY=

# Optional: LiteLLM/OpenAI-compatible gateway provider
# LITELLM_API_BASE=
# LITELLM_API_KEY=
